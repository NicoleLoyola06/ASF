---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio">
  <section class="hero">
    <h1>Adolescencias Sin Ficciones</h1>
    <p>Rompiendo mitos sobre la adolescencia en el Perú</p>
    <a href="/proyectos" class="boton">Conoce nuestros proyectos</a>
  </section>
</Layout>

<style>
  .hero {
    background-color: var(--azul-oscuro);
    color: var(--blanco);
    text-align: center;
    padding: 6rem 2rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--beige);
    margin-bottom: 2rem;
  }

  .boton {
    background-color: var(--naranja);
    color: var(--blanco);
    padding: 0.8rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .boton:hover {
    opacity: 0.85;
  }
</style>