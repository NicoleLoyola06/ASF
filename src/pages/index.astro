---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio">

  <!-- HERO -->
  <section class="hero">
    <h1>Adolescencias Sin Ficciones</h1>
    <p>Rompiendo mitos sobre la adolescencia en el Perú</p>
    <a href="/proyectos" class="boton">Conoce nuestros proyectos</a>
  </section>

  <!-- QUIÉNES SOMOS -->
  <section class="quienes-somos">
    <div class="contenedor">
      <h2>¿Quiénes somos?</h2>
      <div class="cards-info">
        <div class="card-info">
          <span class="icono">🎯</span>
          <h3>Misión</h3>
          <p>Romper mitos acerca de la adolescencia en el público peruano.</p>
        </div>
        <div class="card-info">
          <span class="icono">🔭</span>
          <h3>Visión</h3>
          <p>Ser una agrupación estudiantil conocida a nivel nacional.</p>
        </div>
        <div class="card-info">
          <span class="icono">💪</span>
          <h3>Compromiso</h3>
          <p>Defensa de derechos humanos de los adolescentes y causas sociales.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROYECTOS DESTACADOS -->
  <section class="proyectos-destacados">
    <div class="contenedor">
      <h2>Proyectos destacados</h2>
      <div class="cards-proyectos">
        <div class="card-proyecto">
          <div class="card-tag">Proyecto</div>
          <h3>Difusión en redes sociales</h3>
          <p>Compartimos información basada en evidencia sobre la adolescencia para derribar mitos comunes.</p>
          <a href="/proyectos" class="link">Ver más →</a>
        </div>
        <div class="card-proyecto">
          <div class="card-tag">Intervención</div>
          <h3>Proyectos en instituciones educativas</h3>
          <p>Intervenciones sociales en colegios y universidades para promover los derechos de los adolescentes.</p>
          <a href="/proyectos" class="link">Ver más →</a>
        </div>
        <div class="card-proyecto">
          <div class="card-tag">Defensa</div>
          <h3>Derechos humanos</h3>
          <p>Comprometidos con las causas sociales y la defensa activa de los derechos de los adolescentes peruanos.</p>
          <a href="/proyectos" class="link">Ver más →</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero {
    background-color: var(--azul-oscuro);
    color: var(--blanco);
    text-align: center;
    padding: 6rem 2rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--beige);
    margin-bottom: 2rem;
  }

  .boton {
    background-color: var(--naranja);
    color: var(--blanco);
    padding: 0.8rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .boton:hover {
    opacity: 0.85;
  }

  .contenedor {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* QUIÉNES SOMOS */
  .quienes-somos {
    padding: 5rem 2rem;
    background-color: var(--beige);
  }

  .quienes-somos h2 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 3rem;
    color: var(--azul-oscuro);
  }

  .cards-info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .card-info